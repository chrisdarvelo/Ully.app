{
  "compilerOptions": {
    "target": "esnext",
    "types": [],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "skipLibCheck": true
  },
  "extends": "expo/tsconfig.base",
  "exclude": ["node_modules", "__tests__", "jest.setup.ts", "babel.config.js", "metro.config.js"]
}
